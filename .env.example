# --- Local development (make run / make backend-dev) ---
DATABASE_URL=postgres://switchboard:switchboard@localhost:5432/switchboard?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
APP_BASE_URL=http://localhost:5173
JWT_SESSION_REFRESH_TTL=24h
JWT_REMEMBER_REFRESH_TTL=720h

# Inbound webhooks — leave empty in local dev to skip signature verification
HARBOR_WEBHOOK_SECRET=
TRIVY_WEBHOOK_SECRET=

# --- Production (docker-compose.prod.yml) ---
# POSTGRES_PASSWORD=replace-with-strong-password
# POSTGRES_USER=switchboard
# POSTGRES_DB=switchboard
# JWT_SECRET=replace-with-openssl-rand-base64-32
# APP_BASE_URL=https://switchboard.example.com
# HOST_PORT=8080
# MIGRATE_ON_START=true
# SWITCHBOARD_IMAGE=harbor.example.com/switchboard/switchboard:main-latest

# Optional integrations
# HARBOR_URL=https://harbor.example.com
# HARBOR_TOKEN=robot$project+name:secret   # username:secret (Basic) or bearer token
# TRIVY_URL=
# TRIVY_TOKEN=
# CVE_PULL_ENABLED=false
# CVE_PULL_CRON=0 6 * * 0
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
